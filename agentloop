#!/bin/sh
# The one human entry point for the daily AgentLoop verbs: ./agentloop start | next | ui | agent
# (see src/agentloop/cli.py). Needs only the uv binary — no project environment.
cd "$(dirname "$0")" || exit 1
PYTHONPATH=src exec uv run --no-project --with pyyaml python -m agentloop.cli "$@"
