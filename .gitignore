# ---- Python / uv ----
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.mypy_cache/
.ruff_cache/
.pytest_cache/
build/
dist/
# Commit uv.lock for reproducibility (do not ignore it)

# ---- frontend / pnpm ----
frontend/node_modules/
frontend/dist/
frontend/.vite/

# ---- mkdocs ----
site/

# ---- logs ----
backend/logfiles/*.log
!backend/logfiles/.gitkeep

# ---- AgentLoop runtime artifacts ----
# (.agentloop/events.ndjson — the structured escalation log — is deliberately TRACKED: it is the
#  machine-readable truth behind state.md's generated view and is archived at cycle-close.)
.worktrees/                 # temporary worktrees build_loop.py creates for parallel tasks
.agentloop/build-loop.log   # the pre-events escalation log (legacy; no longer written)
.agentloop/build-loop.log.1 # its rotated previous generation
.agentloop/build-loop.lock  # the single-run PID lock
.agentloop/feedback.yaml    # per-cycle upstream-issue drafts (make feedback); outcomes live in the retrospective
.agentloop/pr-draft.md      # generated PR body (make pr-draft); regenerate rather than track

# ---- environment variables / secrets ----
.env
.env.*
!.env.example

# ---- OS / editor ----
.DS_Store
.idea/
.vscode/

# ---- Claude Code local settings ----
.claude/settings.local.json
