{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/komoroko/AgentLoopTemplate/schema/event.schema.json",
  "title": "AgentLoop events.ndjson record (agentloop-grounded-v1)",
  "description": "One line of the append-only audit log. `event_digest` covers every other field, so a rewritten event breaks its own digest; `prev_event_digest` chains it, so a deleted or reordered event breaks the next one's link. A signed attestation pins the chain root, which is what makes a wholesale re-hash of the log detectable (plan 18.5, E2E-29).",
  "type": "object",
  "additionalProperties": false,
  "required": ["seq", "id", "tx_id", "ts", "event", "cycle_id", "prev_event_digest", "event_digest"],
  "properties": {
    "seq": {
      "description": "Monotonically increasing within the store lock. Duplicates and gaps are both chain violations.",
      "type": "integer",
      "minimum": 1
    },
    "id": { "type": "string", "minLength": 8, "maxLength": 64, "pattern": "^[0-9a-f-]{8,64}$" },
    "tx_id": { "type": "string", "minLength": 8, "maxLength": 64, "pattern": "^[0-9a-f-]{8,64}$" },
    "ts": { "type": "string", "minLength": 10, "maxLength": 64 },
    "event": {
      "enum": [
        "cycle_initialized",
        "source_search_started",
        "source_search_completed",
        "source_unavailable",
        "source_snapshot_created",
        "evidence_obligation_satisfied",
        "evidence_obligation_failed",
        "human_decision_requested",
        "human_decision_attested",
        "knowledge_gap",
        "gate_approval_requested",
        "gate_approved",
        "gate_revised",
        "plan_frozen",
        "plan_invalidated",
        "task_started",
        "task_failed",
        "task_completed",
        "decision_declared",
        "oracle_negative_control_started",
        "oracle_negative_control_passed",
        "oracle_negative_control_failed",
        "oracle_started",
        "oracle_passed",
        "oracle_failed",
        "coverage_generated",
        "actual_extraction_started",
        "actual_extraction_generated",
        "actual_extraction_failed",
        "comparison_generated",
        "security_review_generated",
        "cold_maintainer_generated",
        "review_generated",
        "review_failed",
        "challenge_answered",
        "counterfactual_answered",
        "expert_requested",
        "expert_attested",
        "disposition_recorded",
        "human_review_frozen",
        "human_review_attested",
        "release_verified",
        "release_approved",
        "cycle_closed"
      ]
    },
    "cycle_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "actor": { "type": "string", "maxLength": 200 },
    "subject_ids": { "type": "array", "maxItems": 64, "items": { "type": "string", "maxLength": 64 } },
    "prev_event_digest": {
      "description": "The predecessor's event_digest; the empty string only for seq 1.",
      "oneOf": [{ "const": "" }, { "$ref": "#/$defs/digest" }]
    },
    "event_digest": { "$ref": "#/$defs/digest" },
    "detail": { "type": "object", "maxProperties": 64 }
  },

  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
  }
}
