{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(cat .agentloop/state.md:*)",
      "Bash(cat .agentloop/config.yaml:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git rev-parse:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git merge --ff-only:*)",
      "Bash(git merge --no-ff:*)",
      "Bash(git worktree:*)",
      "Bash(ls:*)",
      "Bash(agentloop status:*)",
      "Bash(agentloop next:*)",
      "Bash(agentloop dag:*)",
      "Bash(agentloop build:*)",
      "Bash(agentloop doctor:*)",
      "Bash(agentloop events:*)",
      "Bash(agentloop revise:*)",
      "Bash(agentloop issue-sync:*)",
      "Bash(agentloop sync --check:*)",
      "Bash(make test:*)",
      "Bash(make check:*)",
      "Bash(make audit:*)",
      "Bash(uv run pytest:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -f .agentloop/state.md && echo '--- AgentLoop current state (top of .agentloop/state.md) ---' && sed -n '1,20p' .agentloop/state.md || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "agentloop guard"
          }
        ]
      }
    ]
  }
}
