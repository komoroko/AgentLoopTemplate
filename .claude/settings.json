{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(cat .agentloop/state.md:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(ls:*)",
      "Bash(make build-loop:*)",
      "Bash(make test-tools:*)",
      "Bash(make issue-sync:*)",
      "Bash(make revise:*)",
      "Bash(make test:*)",
      "Bash(make check:*)",
      "Bash(make audit:*)",
      "Bash(uv run python scripts/agentloop/dag.py:*)",
      "Bash(uv run python scripts/agentloop/build_loop.py:*)",
      "Bash(uv run python scripts/agentloop/issue_sync.py:*)",
      "Bash(uv run python scripts/agentloop/revise.py:*)"
    ],
    "ask": [],
    "deny": []
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -f .agentloop/state.md && echo '--- AgentLoop current state (top of .agentloop/state.md) ---' && sed -n '1,20p' .agentloop/state.md || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project --with pyyaml python scripts/agentloop/gate_guard.py"
          }
        ]
      }
    ]
  }
}
